#!/usr/bin/env python3
"""urixd — демон urix proxy manager."""

import argparse
from urix_config import SOCKET_PATH
from urix_server import run_daemon

parser = argparse.ArgumentParser(prog="urixd", description="urix proxy daemon")
parser.add_argument("--socket", default=SOCKET_PATH, help=f"путь к unix-сокету (default: {SOCKET_PATH})")
args = parser.parse_args()
run_daemon(args.socket)
