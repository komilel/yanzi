#!/usr/bin/env python3
"""urix — клиент proxy manager (без sudo)."""

import argparse
import json
import sys

from urix_config import SOCKET_PATH
from urix_client import UrixClient


def connect():
    try:
        return UrixClient()
    except (ConnectionRefusedError, FileNotFoundError):
        print("urixd не запущен. Запусти: sudo urixd")
        sys.exit(1)


def main():
    parser = argparse.ArgumentParser(prog="urix", description="urix proxy manager")
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("status", help="Статус сервиса")
    sub.add_parser("list", help="Проксируемые приложения")
    sub.add_parser("ui", help="Интерактивный интерфейс")

    p = sub.add_parser("add", help="Добавить PID")
    p.add_argument("pid", type=int)

    p = sub.add_parser("add-name", help="Добавить по имени")
    p.add_argument("name")

    p = sub.add_parser("remove", help="Убрать PID")
    p.add_argument("pid", type=int)

    p = sub.add_parser("run", help="Запустить через прокси")
    p.add_argument("args", nargs=argparse.REMAINDER)

    p = sub.add_parser("sub", help="Подписка")
    p.add_argument("url", nargs="?")

    p = sub.add_parser("ping", help="Пинг серверов")

    args = parser.parse_args()

    if args.command == "ui":
        import curses
        client = connect()
        client.subscribe()
        from urix_tui import tui_main
        try:
            curses.wrapper(lambda stdscr: tui_main(stdscr, client))
        finally:
            client.close()

    elif args.command == "status":
        with connect() as c:
            r = c.call_sync("status")
            xray = f"PID {r['xray_pid']}" if r.get("xray_running") else "не запущен"
            watcher = "да" if r.get("watcher_running") else "нет"
            print(f"Xray:    {xray}")
            print(f"Watcher: {watcher}")
            modes = r.get("active_modes", {})
            active = [k for k, v in modes.items() if v]
            print(f"Режимы:  {', '.join(active) if active else 'нет'}")

    elif args.command == "list":
        with connect() as c:
            apps = c.call_sync("app.list")
            proxied = [a for a in apps if a["proxied_pids"] > 0]
            if not proxied:
                print("Нет проксируемых приложений")
                return
            print(f"{'PID':>7}  {'Приложение':<25}  {'Процессов'}")
            for a in proxied:
                print(f"{a['root_pid']:>7}  {a['name']:<25}  {a['proxied_pids']}/{a['total_pids']}")

    elif args.command == "add":
        with connect() as c:
            r = c.call_sync("app.add", {"pid": args.pid})
            print(f"Добавлен: {r['name']} ({r['count']})")

    elif args.command == "add-name":
        with connect() as c:
            r = c.call_sync("app.add_name", {"name": args.name})
            print(f"Добавлен: {r['name']} ({r['count']} процессов)")

    elif args.command == "remove":
        with connect() as c:
            c.call_sync("app.remove", {"pid": args.pid})
            print(f"Убран: {args.pid}")

    elif args.command == "run":
        if not args.args:
            print("Использование: urix run <команда>")
            sys.exit(1)
        with connect() as c:
            r = c.call_sync("app.run", {"cmd": args.args})
            print(f"Запущен (PID {r['pid']})")

    elif args.command == "sub":
        with connect() as c:
            if args.url:
                r = c.call_sync("sub.load", {"url": args.url})
                print(f"Загружено: {r['count']} серверов")
            else:
                r = c.call_sync("sub.update")
                print(f"Обновлено: {r['count']} серверов")
            # Show server list
            servers = c.call_sync("server.list")
            for s in servers:
                m = ">" if s["active"] else " "
                print(f"  {m} [{s['index']}] {s['name']} ({s['proto']})")

    elif args.command == "ping":
        with connect() as c:
            servers = c.call_sync("server.list")
            print("Пингую серверы...")
            # Use sync ping-one for CLI
            for s in servers:
                r = c.call_sync("server.ping_one", {"index": s["index"]})
                ms = r.get("ms")
                ms_str = f"{ms}ms" if ms is not None else "fail"
                print(f"  [{s['index']}] {s['name']:<35} {ms_str}")

    else:
        parser.print_help()


if __name__ == "__main__":
    main()
